{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LT7XfZPagncPpFQTu5C8Rq","type":"tool_result","content":"1\t\"\"\"seed_storage/config.py — All configuration via pydantic-settings Settings class.\n2\t\n3\tProvides a Settings singleton with validators for credentials, providers, and constants.\n4\tFile-mode credentials (ant-keeper managed) are loaded from path env vars.\n5\tLogging utilities live here to keep sensitive values in one place.\n6\t\"\"\"\n7\t\n8\tfrom __future__ import annotations\n9\t\n10\timport json\n11\timport logging\n12\timport re\n13\timport time\n14\tfrom collections.abc import Generator\n15\tfrom contextlib import contextmanager\n16\tfrom pathlib import Path\n17\tfrom typing import Any\n18\t\n19\tfrom pydantic import field_validator, model_validator\n20\tfrom pydantic_settings import BaseSettings, SettingsConfigDict\n21\t\n22\t# ---------------------------------------------------------------------------\n23\t# Helpers\n24\t# ---------------------------------------------------------------------------\n25\t\n26\t\n27\tdef _read_file(path: str) -> str:\n28\t    \"\"\"Read a credential from a file path, stripping surrounding whitespace.\"\"\"\n29\t    p = Path(path)\n30\t    if p.exists():\n31\t        return p.read_text().strip()\n32\t    return \"\"\n33\t\n34\t\n35\t# ---------------------------------------------------------------------------\n36\t# Settings class\n37\t# ---------------------------------------------------------------------------\n38\t\n39\t\n40\tclass Settings(BaseSettings):\n41\t    \"\"\"All seed-storage configuration in one place.\n42\t\n43\t    Env vars override .env file values (standard pydantic-settings behaviour).\n44\t    File-mode credentials (ant-keeper) are resolved after env-var loading.\n45\t\n46\t    Call ``validate_credentials()`` at application startup to fail fast on\n47\t    missing required API keys / tokens — this is intentionally NOT done at\n48\t    construction time so the module can be imported in test/dev environments\n49\t    without all credentials present.\n50\t    \"\"\"\n51\t\n52\t    model_config = SettingsConfigDict(\n53\t        env_file=\".env\",\n54\t        env_file_encoding=\"utf-8\",\n55\t        extra=\"ignore\",\n56\t    )\n57\t\n58\t    # --- Neo4j ---\n59\t    NEO4J_URI: str = \"bolt://neo4j.ant-keeper.svc:7687\"\n60\t    NEO4J_USER: str = \"neo4j\"\n61\t    NEO4J_PASSWORD: str = \"\"\n62\t    NEO4J_PASSWORD_PATH: str = \"\"\n63\t\n64\t    # --- Redis (DB 2 — isolated from ant-keeper on DB 0) ---\n65\t    REDIS_URL: str = \"redis://redis.ant-keeper.svc:6379/2\"\n66\t\n67\t    # --- Discord Bot ---\n68\t    DISCORD_BOT_TOKEN: str = \"\"\n69\t    DISCORD_BOT_TOKEN_PATH: str = \"\"\n70\t    DISCORD_CHANNEL_IDS: str = \"\"  # comma-separated channel snowflakes\n71\t\n72\t    # --- Discord Alerts Webhook ---\n73\t    DISCORD_ALERTS_WEBHOOK_URL: str = \"\"\n74\t    DISCORD_ALERTS_WEBHOOK_PATH: str = \"\"\n75\t\n76\t    # --- LLM provider ---\n77\t    LLM_PROVIDER: str = \"openai\"  # openai | anthropic | groq\n78\t    OPENAI_API_KEY: str = \"\"  # required for embeddings regardless of LLM_PROVIDER\n79\t    ANTHROPIC_API_KEY: str = \"\"\n80\t    GROQ_API_KEY: str = \"\"\n81\t    LLM_MODEL: str = \"gpt-4o-mini\"\n82\t\n83\t    # --- Vision ---\n84\t    VISION_PROVIDER: str = \"\"  # defaults to LLM_PROVIDER when empty\n85\t\n86\t    # --- Transcription ---\n87\t    TRANSCRIPTION_BACKEND: str = \"whisper\"  # whisper | assemblyai\n88\t    ASSEMBLYAI_API_KEY: str = \"\"\n89\t\n90\t    # --- GitHub (optional) ---\n91\t    GITHUB_TOKEN: str = \"\"\n92\t    GITHUB_TOKEN_PATH: str = \"\"\n93\t\n94\t    # --- Budget / expansion limits ---\n95\t    DAILY_LLM_BUDGET: float = 5.00\n96\t    HARD_DEPTH_CEILING: int = 5\n97\t    MAX_EXPANSION_BREADTH: int = 20\n98\t    FRONTIER_AUTO_ENABLED: bool = False\n99\t    RATE_LIMIT_PER_MINUTE: int = 100\n100\t\n101\t    # --- Worker ---\n102\t    WORKER_CONCURRENCY_RAW: int = 2\n103\t    WORKER_CONCURRENCY_GRAPH: int = 4\n104\t\n105\t    # --- API / Health ---\n106\t    API_HOST: str = \"0.0.0.0\"\n107\t    API_PORT: int = 7860\n108\t    HEALTH_PORT: int = 8080\n109\t\n110\t    # --- Graphiti ---\n111\t    GROUP_ID: str = \"seed-storage\"\n112\t\n113\t    # --- PostgreSQL (v1 staging table, shared with ant-keeper) ---\n114\t    PG_DSN: str = \"postgresql://taskman:postgres@127.0.0.1:30433/task_manager\"\n115\t\n116\t    # --- Log level ---\n117\t    LOG_LEVEL: str = \"INFO\"\n118\t\n119\t    # -----------------------------------------------------------------------\n120\t    # Field validators (run before model validators)\n121\t    # -----------------------------------------------------------------------\n122\t\n123\t    @field_validator(\"LLM_PROVIDER\")\n124\t    @classmethod\n125\t    def _validate_llm_provider(cls, v: str) -> str:\n126\t        allowed = {\"openai\", \"anthropic\", \"groq\"}\n127\t        if v not in allowed:\n128\t            raise ValueError(f\"LLM_PROVIDER must be one of {sorted(allowed)}, got {v!r}\")\n129\t        return v\n130\t\n131\t    @field_validator(\"TRANSCRIPTION_BACKEND\")\n132\t    @classmethod\n133\t    def _validate_transcription_backend(cls, v: str) -> str:\n134\t        allowed = {\"whisper\", \"assemblyai\"}\n135\t        if v not in allowed:\n136\t            raise ValueError(f\"TRANSCRIPTION_BACKEND must be one of {sorted(allowed)}, got {v!r}\")\n137\t        return v\n138\t\n139\t    # -----------------------------------------------------------------------\n140\t    # Model validators (run after all fields are set)\n141\t    # -----------------------------------------------------------------------\n142\t\n143\t    @model_validator(mode=\"after\")\n144\t    def _resolve_file_credentials(self) -> Settings:\n145\t        \"\"\"Load file-mode credentials (ant-keeper managed paths).\"\"\"\n146\t        pairs = [\n147\t            (\"NEO4J_PASSWORD_PATH\", \"NEO4J_PASSWORD\"),\n148\t            (\"DISCORD_BOT_TOKEN_PATH\", \"DISCORD_BOT_TOKEN\"),\n149\t            (\"DISCORD_ALERTS_WEBHOOK_PATH\", \"DISCORD_ALERTS_WEBHOOK_URL\"),\n150\t            (\"GITHUB_TOKEN_PATH\", \"GITHUB_TOKEN\"),\n151\t        ]\n152\t        for path_field, value_field in pairs:\n153\t            path = getattr(self, path_field)\n154\t            if path and not getattr(self, value_field):\n155\t                val = _read_file(path)\n156\t                if val:\n157\t                    object.__setattr__(self, value_field, val)\n158\t        return self\n159\t\n160\t    @model_validator(mode=\"after\")\n161\t    def _resolve_vision_provider(self) -> Settings:\n162\t        \"\"\"Default VISION_PROVIDER to LLM_PROVIDER when not explicitly set.\"\"\"\n163\t        if not self.VISION_PROVIDER:\n164\t            object.__setattr__(self, \"VISION_PROVIDER\", self.LLM_PROVIDER)\n165\t        return self\n166\t\n167\t    # -----------------------------------------------------------------------\n168\t    # Computed properties\n169\t    # -----------------------------------------------------------------------\n170\t\n171\t    @property\n172\t    def llm_api_key(self) -> str:\n173\t        \"\"\"Return the API key for the configured LLM provider.\"\"\"\n174\t        return {\n175\t            \"openai\": self.OPENAI_API_KEY,\n176\t            \"anthropic\": self.ANTHROPIC_API_KEY,\n177\t            \"groq\": self.GROQ_API_KEY,\n178\t        }.get(self.LLM_PROVIDER, \"\")\n179\t\n180\t    @property\n181\t    def discord_channel_ids(self) -> list[str]:\n182\t        \"\"\"Parse DISCORD_CHANNEL_IDS from comma-separated string into a list.\"\"\"\n183\t        if not self.DISCORD_CHANNEL_IDS:\n184\t            return []\n185\t        return [cid.strip() for cid in self.DISCORD_CHANNEL_IDS.split(\",\") if cid.strip()]\n186\t\n187\t    # -----------------------------------------------------------------------\n188\t    # Production credential validation\n189\t    # -----------------------------------------------------------------------\n190\t\n191\t    def validate_credentials(self) -> None:\n192\t        \"\"\"Raise ValueError if required production credentials are missing.\n193\t\n194\t        This is NOT called at construction time. Call it at application startup\n195\t        (e.g., in main() or bot on_ready) to fail fast before any LLM/Discord\n196\t        operations are attempted.\n197\t        \"\"\"\n198\t        if not self.llm_api_key:\n199\t            raise ValueError(\n200\t                f\"LLM_PROVIDER is {self.LLM_PROVIDER!r} but the corresponding API key is\"\n201\t                f\" missing. Set {self.LLM_PROVIDER.upper()}_API_KEY.\"\n202\t            )\n203\t        if not self.OPENAI_API_KEY:\n204\t            raise ValueError(\n205\t                \"OPENAI_API_KEY is required for embeddings regardless of LLM_PROVIDER.\"\n206\t            )\n207\t        if not self.DISCORD_BOT_TOKEN:\n208\t            raise ValueError(\n209\t                \"DISCORD_BOT_TOKEN is missing. Set DISCORD_BOT_TOKEN or DISCORD_BOT_TOKEN_PATH.\"\n210\t            )\n211\t\n212\t\n213\t# ---------------------------------------------------------------------------\n214\t# Module-level singleton\n215\t# ---------------------------------------------------------------------------\n216\t\n217\tsettings = Settings()\n218\t\n219\t# Backwards-compat module-level alias used by v1 staging.py\n220\tPG_DSN = settings.PG_DSN\n221\t\n222\t\n223\t# ---------------------------------------------------------------------------\n224\t# Logging utilities\n225\t# ---------------------------------------------------------------------------\n226\t\n227\t# Patterns for credentials that must never appear in logs.\n228\t# Patterns are built at runtime to avoid literal key-prefix strings in source.\n229\t_SK_PREFIX = \"sk\"\n230\t_ANT_INFIX = \"ant\"\n231\t_SECRET_PATTERNS: list[re.Pattern[str]] = [\n232\t    re.compile(_SK_PREFIX + r\"-[A-Za-z0-9\\-_]{20,}\"),  # OpenAI / generic sk- keys\n233\t    re.compile(_SK_PREFIX + \"-\" + _ANT_INFIX + r\"-[A-Za-z0-9\\-_]{20,}\"),  # Anthropic keys\n234\t    re.compile(r\"gsk_[A-Za-z0-9]{20,}\"),  # Groq keys\n235\t    re.compile(r\"Bot\\s+[A-Za-z0-9\\-_.]{30,}\"),  # Discord bot tokens (Bot <token>)\n236\t    re.compile(r\"Bearer\\s+[A-Za-z0-9\\-_.]{20,}\"),  # Bearer tokens\n237\t]\n238\t\n239\t_MASK = \"***MASKED***\"\n240\t\n241\t\n242\tdef _mask_secrets(text: str) -> str:\n243\t    \"\"\"Replace recognised credential patterns with ``***MASKED***``.\"\"\"\n244\t    for pattern in _SECRET_PATTERNS:\n245\t        text = pattern.sub(_MASK, text)\n246\t    return text\n247\t\n248\t\n249\tclass _JsonFormatter(logging.Formatter):\n250\t    \"\"\"Emit log records as single-line JSON objects.\"\"\"\n251\t\n252\t    def format(self, record: logging.LogRecord) -> str:\n253\t        message = _mask_secrets(record.getMessage())\n254\t        data: dict[str, Any] = {\n255\t            \"timestamp\": self.formatTime(record, self.datefmt),\n256\t            \"level\": record.levelname,\n257\t            \"name\": record.name,\n258\t            \"message\": message,\n259\t        }\n260\t        if hasattr(record, \"duration_ms\"):\n261\t            data[\"duration_ms\"] = record.duration_ms\n262\t        if record.exc_info:\n263\t            data[\"exc_info\"] = self.formatException(record.exc_info)\n264\t        return json.dumps(data)\n265\t\n266\t\n267\tclass _SecretMaskingFilter(logging.Filter):\n268\t    \"\"\"Mask secrets in log record message and args before any handler sees them.\"\"\"\n269\t\n270\t    def filter(self, record: logging.LogRecord) -> bool:\n271\t        record.msg = _mask_secrets(str(record.msg))\n272\t        if record.args:\n273\t            if isinstance(record.args, dict):\n274\t                record.args = {\n275\t                    k: _mask_secrets(str(v)) if isinstance(v, str) else v\n276\t                    for k, v in record.args.items()\n277\t                }\n278\t            elif isinstance(record.args, tuple):\n279\t                record.args = tuple(\n280\t                    _mask_secrets(str(a)) if isinstance(a, str) else a for a in record.args\n281\t                )\n282\t        return True\n283\t\n284\t\n285\tdef configure_logging(level: str | None = None) -> None:\n286\t    \"\"\"Configure structured JSON logging with secret masking for all handlers.\n287\t\n288\t    Idempotent — safe to call multiple times (replaces existing handlers).\n289\t\n290\t    Args:\n291\t        level: Log level string (e.g. \"DEBUG\", \"INFO\"). Defaults to\n292\t               ``settings.LOG_LEVEL`` when not provided.\n293\t    \"\"\"\n294\t    log_level = getattr(logging, (level or settings.LOG_LEVEL).upper(), logging.INFO)\n295\t\n296\t    handler = logging.StreamHandler()\n297\t    handler.setFormatter(_JsonFormatter())\n298\t    handler.addFilter(_SecretMaskingFilter())\n299\t\n300\t    root = logging.getLogger()\n301\t    root.setLevel(log_level)\n302\t    root.handlers = [handler]\n303\t\n304\t\n305\t@contextmanager\n306\tdef task_log(\n307\t    logger: logging.Logger,\n308\t    task_name: str,\n309\t    log_level: int = logging.INFO,\n310\t    **extra: Any,\n311\t) -> Generator[None, None, None]:\n312\t    \"\"\"Context manager that logs task completion with elapsed ``duration_ms``.\n313\t\n314\t    Usage::\n315\t\n316\t        with task_log(logger, \"enrich_message\", source_id=\"123\"):\n317\t            do_work()\n318\t\n319\t    On exit (normal or exception), emits a log record with ``duration_ms``\n320\t    set to elapsed milliseconds. On exception, the exception is re-raised.\n321\t    \"\"\"\n322\t    start = time.monotonic()\n323\t    try:\n324\t        yield\n325\t    finally:\n326\t        duration_ms = int((time.monotonic() - start) * 1000)\n327\t        record = logger.makeRecord(\n328\t            name=logger.name,\n329\t            level=log_level,\n330\t            fn=\"\",\n331\t            lno=0,\n332\t            msg=\"task_complete: %s\",\n333\t            args=(task_name,),\n334\t            exc_info=None,\n335\t        )\n336\t        record.duration_ms = duration_ms\n337\t        for k, v in extra.items():\n338\t            setattr(record, k, v)\n339\t        logger.handle(record)\n340\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"57251451-71b9-447a-8e1e-4d99539adbf5","uuid":"9f664738-3e5c-4d20-a692-d61e60f6f2b4","timestamp":"2026-04-19T02:28:53.532Z","tool_use_result":{"type":"text","file":{"filePath":"/home/wyler-zahm/Desktop/cruse-control/seed-storage-forge/seed_storage/config.py","content":"\"\"\"seed_storage/config.py — All configuration via pydantic-settings Settings class.\n\nProvides a Settings singleton with validators for credentials, providers, and constants.\nFile-mode credentials (ant-keeper managed) are loaded from path env vars.\nLogging utilities live here to keep sensitive values in one place.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport logging\nimport re\nimport time\nfrom collections.abc import Generator\nfrom contextlib import contextmanager\nfrom pathlib import Path\nfrom typing import Any\n\nfrom pydantic import field_validator, model_validator\nfrom pydantic_settings import BaseSettings, SettingsConfigDict\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\n\ndef _read_file(path: str) -> str:\n    \"\"\"Read a credential from a file path, stripping surrounding whitespace.\"\"\"\n    p = Path(path)\n    if p.exists():\n        return p.read_text().strip()\n    return \"\"\n\n\n# ---------------------------------------------------------------------------\n# Settings class\n# ---------------------------------------------------------------------------\n\n\nclass Settings(BaseSettings):\n    \"\"\"All seed-storage configuration in one place.\n\n    Env vars override .env file values (standard pydantic-settings behaviour).\n    File-mode credentials (ant-keeper) are resolved after env-var loading.\n\n    Call ``validate_credentials()`` at application startup to fail fast on\n    missing required API keys / tokens — this is intentionally NOT done at\n    construction time so the module can be imported in test/dev environments\n    without all credentials present.\n    \"\"\"\n\n    model_config = SettingsConfigDict(\n        env_file=\".env\",\n        env_file_encoding=\"utf-8\",\n        extra=\"ignore\",\n    )\n\n    # --- Neo4j ---\n    NEO4J_URI: str = \"bolt://neo4j.ant-keeper.svc:7687\"\n    NEO4J_USER: str = \"neo4j\"\n    NEO4J_PASSWORD: str = \"\"\n    NEO4J_PASSWORD_PATH: str = \"\"\n\n    # --- Redis (DB 2 — isolated from ant-keeper on DB 0) ---\n    REDIS_URL: str = \"redis://redis.ant-keeper.svc:6379/2\"\n\n    # --- Discord Bot ---\n    DISCORD_BOT_TOKEN: str = \"\"\n    DISCORD_BOT_TOKEN_PATH: str = \"\"\n    DISCORD_CHANNEL_IDS: str = \"\"  # comma-separated channel snowflakes\n\n    # --- Discord Alerts Webhook ---\n    DISCORD_ALERTS_WEBHOOK_URL: str = \"\"\n    DISCORD_ALERTS_WEBHOOK_PATH: str = \"\"\n\n    # --- LLM provider ---\n    LLM_PROVIDER: str = \"openai\"  # openai | anthropic | groq\n    OPENAI_API_KEY: str = \"\"  # required for embeddings regardless of LLM_PROVIDER\n    ANTHROPIC_API_KEY: str = \"\"\n    GROQ_API_KEY: str = \"\"\n    LLM_MODEL: str = \"gpt-4o-mini\"\n\n    # --- Vision ---\n    VISION_PROVIDER: str = \"\"  # defaults to LLM_PROVIDER when empty\n\n    # --- Transcription ---\n    TRANSCRIPTION_BACKEND: str = \"whisper\"  # whisper | assemblyai\n    ASSEMBLYAI_API_KEY: str = \"\"\n\n    # --- GitHub (optional) ---\n    GITHUB_TOKEN: str = \"\"\n    GITHUB_TOKEN_PATH: str = \"\"\n\n    # --- Budget / expansion limits ---\n    DAILY_LLM_BUDGET: float = 5.00\n    HARD_DEPTH_CEILING: int = 5\n    MAX_EXPANSION_BREADTH: int = 20\n    FRONTIER_AUTO_ENABLED: bool = False\n    RATE_LIMIT_PER_MINUTE: int = 100\n\n    # --- Worker ---\n    WORKER_CONCURRENCY_RAW: int = 2\n    WORKER_CONCURRENCY_GRAPH: int = 4\n\n    # --- API / Health ---\n    API_HOST: str = \"0.0.0.0\"\n    API_PORT: int = 7860\n    HEALTH_PORT: int = 8080\n\n    # --- Graphiti ---\n    GROUP_ID: str = \"seed-storage\"\n\n    # --- PostgreSQL (v1 staging table, shared with ant-keeper) ---\n    PG_DSN: str = \"postgresql://taskman:postgres@127.0.0.1:30433/task_manager\"\n\n    # --- Log level ---\n    LOG_LEVEL: str = \"INFO\"\n\n    # -----------------------------------------------------------------------\n    # Field validators (run before model validators)\n    # -----------------------------------------------------------------------\n\n    @field_validator(\"LLM_PROVIDER\")\n    @classmethod\n    def _validate_llm_provider(cls, v: str) -> str:\n        allowed = {\"openai\", \"anthropic\", \"groq\"}\n        if v not in allowed:\n            raise ValueError(f\"LLM_PROVIDER must be one of {sorted(allowed)}, got {v!r}\")\n        return v\n\n    @field_validator(\"TRANSCRIPTION_BACKEND\")\n    @classmethod\n    def _validate_transcription_backend(cls, v: str) -> str:\n        allowed = {\"whisper\", \"assemblyai\"}\n        if v not in allowed:\n            raise ValueError(f\"TRANSCRIPTION_BACKEND must be one of {sorted(allowed)}, got {v!r}\")\n        return v\n\n    # -----------------------------------------------------------------------\n    # Model validators (run after all fields are set)\n    # -----------------------------------------------------------------------\n\n    @model_validator(mode=\"after\")\n    def _resolve_file_credentials(self) -> Settings:\n        \"\"\"Load file-mode credentials (ant-keeper managed paths).\"\"\"\n        pairs = [\n            (\"NEO4J_PASSWORD_PATH\", \"NEO4J_PASSWORD\"),\n            (\"DISCORD_BOT_TOKEN_PATH\", \"DISCORD_BOT_TOKEN\"),\n            (\"DISCORD_ALERTS_WEBHOOK_PATH\", \"DISCORD_ALERTS_WEBHOOK_URL\"),\n            (\"GITHUB_TOKEN_PATH\", \"GITHUB_TOKEN\"),\n        ]\n        for path_field, value_field in pairs:\n            path = getattr(self, path_field)\n            if path and not getattr(self, value_field):\n                val = _read_file(path)\n                if val:\n                    object.__setattr__(self, value_field, val)\n        return self\n\n    @model_validator(mode=\"after\")\n    def _resolve_vision_provider(self) -> Settings:\n        \"\"\"Default VISION_PROVIDER to LLM_PROVIDER when not explicitly set.\"\"\"\n        if not self.VISION_PROVIDER:\n            object.__setattr__(self, \"VISION_PROVIDER\", self.LLM_PROVIDER)\n        return self\n\n    # -----------------------------------------------------------------------\n    # Computed properties\n    # -----------------------------------------------------------------------\n\n    @property\n    def llm_api_key(self) -> str:\n        \"\"\"Return the API key for the configured LLM provider.\"\"\"\n        return {\n            \"openai\": self.OPENAI_API_KEY,\n            \"anthropic\": self.ANTHROPIC_API_KEY,\n            \"groq\": self.GROQ_API_KEY,\n        }.get(self.LLM_PROVIDER, \"\")\n\n    @property\n    def discord_channel_ids(self) -> list[str]:\n        \"\"\"Parse DISCORD_CHANNEL_IDS from comma-separated string into a list.\"\"\"\n        if not self.DISCORD_CHANNEL_IDS:\n            return []\n        return [cid.strip() for cid in self.DISCORD_CHANNEL_IDS.split(\",\") if cid.strip()]\n\n    # -----------------------------------------------------------------------\n    # Production credential validation\n    # -----------------------------------------------------------------------\n\n    def validate_credentials(self) -> None:\n        \"\"\"Raise ValueError if required production credentials are missing.\n\n        This is NOT called at construction time. Call it at application startup\n        (e.g., in main() or bot on_ready) to fail fast before any LLM/Discord\n        operations are attempted.\n        \"\"\"\n        if not self.llm_api_key:\n            raise ValueError(\n                f\"LLM_PROVIDER is {self.LLM_PROVIDER!r} but the corresponding API key is\"\n                f\" missing. Set {self.LLM_PROVIDER.upper()}_API_KEY.\"\n            )\n        if not self.OPENAI_API_KEY:\n            raise ValueError(\n                \"OPENAI_API_KEY is required for embeddings regardless of LLM_PROVIDER.\"\n            )\n        if not self.DISCORD_BOT_TOKEN:\n            raise ValueError(\n                \"DISCORD_BOT_TOKEN is missing. Set DISCORD_BOT_TOKEN or DISCORD_BOT_TOKEN_PATH.\"\n            )\n\n\n# ---------------------------------------------------------------------------\n# Module-level singleton\n# ---------------------------------------------------------------------------\n\nsettings = Settings()\n\n# Backwards-compat module-level alias used by v1 staging.py\nPG_DSN = settings.PG_DSN\n\n\n# ---------------------------------------------------------------------------\n# Logging utilities\n# ---------------------------------------------------------------------------\n\n# Patterns for credentials that must never appear in logs.\n# Patterns are built at runtime to avoid literal key-prefix strings in source.\n_SK_PREFIX = \"sk\"\n_ANT_INFIX = \"ant\"\n_SECRET_PATTERNS: list[re.Pattern[str]] = [\n    re.compile(_SK_PREFIX + r\"-[A-Za-z0-9\\-_]{20,}\"),  # OpenAI / generic sk- keys\n    re.compile(_SK_PREFIX + \"-\" + _ANT_INFIX + r\"-[A-Za-z0-9\\-_]{20,}\"),  # Anthropic keys\n    re.compile(r\"gsk_[A-Za-z0-9]{20,}\"),  # Groq keys\n    re.compile(r\"Bot\\s+[A-Za-z0-9\\-_.]{30,}\"),  # Discord bot tokens (Bot <token>)\n    re.compile(r\"Bearer\\s+[A-Za-z0-9\\-_.]{20,}\"),  # Bearer tokens\n]\n\n_MASK = \"***MASKED***\"\n\n\ndef _mask_secrets(text: str) -> str:\n    \"\"\"Replace recognised credential patterns with ``***MASKED***``.\"\"\"\n    for pattern in _SECRET_PATTERNS:\n        text = pattern.sub(_MASK, text)\n    return text\n\n\nclass _JsonFormatter(logging.Formatter):\n    \"\"\"Emit log records as single-line JSON objects.\"\"\"\n\n    def format(self, record: logging.LogRecord) -> str:\n        message = _mask_secrets(record.getMessage())\n        data: dict[str, Any] = {\n            \"timestamp\": self.formatTime(record, self.datefmt),\n            \"level\": record.levelname,\n            \"name\": record.name,\n            \"message\": message,\n        }\n        if hasattr(record, \"duration_ms\"):\n            data[\"duration_ms\"] = record.duration_ms\n        if record.exc_info:\n            data[\"exc_info\"] = self.formatException(record.exc_info)\n        return json.dumps(data)\n\n\nclass _SecretMaskingFilter(logging.Filter):\n    \"\"\"Mask secrets in log record message and args before any handler sees them.\"\"\"\n\n    def filter(self, record: logging.LogRecord) -> bool:\n        record.msg = _mask_secrets(str(record.msg))\n        if record.args:\n            if isinstance(record.args, dict):\n                record.args = {\n                    k: _mask_secrets(str(v)) if isinstance(v, str) else v\n                    for k, v in record.args.items()\n                }\n            elif isinstance(record.args, tuple):\n                record.args = tuple(\n                    _mask_secrets(str(a)) if isinstance(a, str) else a for a in record.args\n                )\n        return True\n\n\ndef configure_logging(level: str | None = None) -> None:\n    \"\"\"Configure structured JSON logging with secret masking for all handlers.\n\n    Idempotent — safe to call multiple times (replaces existing handlers).\n\n    Args:\n        level: Log level string (e.g. \"DEBUG\", \"INFO\"). Defaults to\n               ``settings.LOG_LEVEL`` when not provided.\n    \"\"\"\n    log_level = getattr(logging, (level or settings.LOG_LEVEL).upper(), logging.INFO)\n\n    handler = logging.StreamHandler()\n    handler.setFormatter(_JsonFormatter())\n    handler.addFilter(_SecretMaskingFilter())\n\n    root = logging.getLogger()\n    root.setLevel(log_level)\n    root.handlers = [handler]\n\n\n@contextmanager\ndef task_log(\n    logger: logging.Logger,\n    task_name: str,\n    log_level: int = logging.INFO,\n    **extra: Any,\n) -> Generator[None, None, None]:\n    \"\"\"Context manager that logs task completion with elapsed ``duration_ms``.\n\n    Usage::\n\n        with task_log(logger, \"enrich_message\", source_id=\"123\"):\n            do_work()\n\n    On exit (normal or exception), emits a log record with ``duration_ms``\n    set to elapsed milliseconds. On exception, the exception is re-raised.\n    \"\"\"\n    start = time.monotonic()\n    try:\n        yield\n    finally:\n        duration_ms = int((time.monotonic() - start) * 1000)\n        record = logger.makeRecord(\n            name=logger.name,\n            level=log_level,\n            fn=\"\",\n            lno=0,\n            msg=\"task_complete: %s\",\n            args=(task_name,),\n            exc_info=None,\n        )\n        record.duration_ms = duration_ms\n        for k, v in extra.items():\n            setattr(record, k, v)\n        logger.handle(record)\n","numLines":340,"startLine":1,"totalLines":340}}}
