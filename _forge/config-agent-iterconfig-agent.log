{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TZDsa1X13ACoQi8oKQjhFu","type":"tool_result","content":"1\t\"\"\"Unit tests for seed_storage.config logging utilities.\n2\t\n3\tTests JSON formatting, secret masking, required log fields, and task_log\n4\tduration tracking. No real infrastructure or credentials required.\n5\t\"\"\"\n6\t\n7\tfrom __future__ import annotations\n8\t\n9\timport json\n10\timport logging\n11\t\n12\timport pytest\n13\t\n14\tfrom seed_storage.config import (\n15\t    _JsonFormatter,\n16\t    _mask_secrets,\n17\t    _SecretMaskingFilter,\n18\t    configure_logging,\n19\t    task_log,\n20\t)\n21\t\n22\t# ---------------------------------------------------------------------------\n23\t# Helpers\n24\t# ---------------------------------------------------------------------------\n25\t\n26\t\n27\tdef _capture_record(msg: str, level: int = logging.INFO, **kwargs) -> str:\n28\t    \"\"\"Emit a log record through JsonFormatter and return the JSON string.\"\"\"\n29\t    formatter = _JsonFormatter()\n30\t    record = logging.LogRecord(\n31\t        name=\"test.logger\",\n32\t        level=level,\n33\t        pathname=\"\",\n34\t        lineno=0,\n35\t        msg=msg,\n36\t        args=(),\n37\t        exc_info=None,\n38\t    )\n39\t    for k, v in kwargs.items():\n40\t        setattr(record, k, v)\n41\t    return formatter.format(record)\n42\t\n43\t\n44\t# ---------------------------------------------------------------------------\n45\t# JSON format\n46\t# ---------------------------------------------------------------------------\n47\t\n48\t\n49\tclass TestJsonFormat:\n50\t    def test_output_is_valid_json(self):\n51\t        output = _capture_record(\"hello world\")\n52\t        parsed = json.loads(output)  # raises if not valid JSON\n53\t        assert isinstance(parsed, dict)\n54\t\n55\t    def test_required_fields_present(self):\n56\t        parsed = json.loads(_capture_record(\"test message\"))\n57\t        assert \"timestamp\" in parsed\n58\t        assert \"level\" in parsed\n59\t        assert \"name\" in parsed\n60\t        assert \"message\" in parsed\n61\t\n62\t    def test_message_field_contains_log_text(self):\n63\t        parsed = json.loads(_capture_record(\"specific log text\"))\n64\t        assert parsed[\"message\"] == \"specific log text\"\n65\t\n66\t    def test_level_field_matches_log_level(self):\n67\t        parsed = json.loads(_capture_record(\"msg\", level=logging.WARNING))\n68\t        assert parsed[\"level\"] == \"WARNING\"\n69\t\n70\t    def test_name_field_contains_logger_name(self):\n71\t        parsed = json.loads(_capture_record(\"msg\"))\n72\t        assert parsed[\"name\"] == \"test.logger\"\n73\t\n74\t    def test_duration_ms_included_when_present(self):\n75\t        parsed = json.loads(_capture_record(\"msg\", duration_ms=123))\n76\t        assert parsed[\"duration_ms\"] == 123\n77\t\n78\t    def test_duration_ms_absent_when_not_set(self):\n79\t        parsed = json.loads(_capture_record(\"msg\"))\n80\t        assert \"duration_ms\" not in parsed\n81\t\n82\t\n83\t# ---------------------------------------------------------------------------\n84\t# Secret masking\n85\t# ---------------------------------------------------------------------------\n86\t\n87\t\n88\tclass TestSecretMasking:\n89\t    def test_openai_key_masked_in_message(self):\n90\t        output = _capture_record(\"api_key=sk-1234567890abcdef1234567890\")\n91\t        parsed = json.loads(output)\n92\t        assert \"sk-1234567890\" not in parsed[\"message\"]\n93\t        assert \"***MASKED***\" in parsed[\"message\"]\n94\t\n95\t    def test_anthropic_key_masked(self):\n96\t        output = _capture_record(\"key=sk-ant-api03-abcdefghijklmnopqrstuvwxyz123456\")\n97\t        parsed = json.loads(output)\n98\t        assert \"sk-ant-api03\" not in parsed[\"message\"]\n99\t        assert \"***MASKED***\" in parsed[\"message\"]\n100\t\n101\t    def test_groq_key_masked(self):\n102\t        output = _capture_record(\"key=gsk_abcdefghijklmnopqrstuvwxyz12345678\")\n103\t        parsed = json.loads(output)\n104\t        assert \"gsk_abcdefghijklmnopqrstuvwxyz\" not in parsed[\"message\"]\n105\t        assert \"***MASKED***\" in parsed[\"message\"]\n106\t\n107\t    def test_normal_text_not_masked(self):\n108\t        output = _capture_record(\"processing message from #general\")\n109\t        parsed = json.loads(output)\n110\t        assert parsed[\"message\"] == \"processing message from #general\"\n111\t\n112\t    def test_masking_at_debug_level(self):\n113\t        \"\"\"Secrets must be masked even at DEBUG level.\"\"\"\n114\t        output = _capture_record(\"debug: sk-1234567890abcdefghijklmnop\", level=logging.DEBUG)\n115\t        parsed = json.loads(output)\n116\t        assert \"sk-1234567890\" not in parsed[\"message\"]\n117\t        assert \"***MASKED***\" in parsed[\"message\"]\n118\t\n119\t\n120\t# ---------------------------------------------------------------------------\n121\t# _mask_secrets helper\n122\t# ---------------------------------------------------------------------------\n123\t\n124\t\n125\tclass TestMaskSecretsHelper:\n126\t    def test_openai_key_masked(self):\n127\t        result = _mask_secrets(\"key=sk-proj-1234567890abcdefghijklmnop\")\n128\t        assert \"sk-proj-1234567890\" not in result\n129\t        assert \"***MASKED***\" in result\n130\t\n131\t    def test_plain_text_unchanged(self):\n132\t        text = \"no secrets here\"\n133\t        assert _mask_secrets(text) == text\n134\t\n135\t    def test_empty_string_unchanged(self):\n136\t        assert _mask_secrets(\"\") == \"\"\n137\t\n138\t\n139\t# ---------------------------------------------------------------------------\n140\t# SecretMaskingFilter\n141\t# ---------------------------------------------------------------------------\n142\t\n143\t\n144\tclass TestSecretMaskingFilter:\n145\t    def test_filter_masks_record_msg(self):\n146\t        filt = _SecretMaskingFilter()\n147\t        record = logging.LogRecord(\n148\t            name=\"test\",\n149\t            level=logging.INFO,\n150\t            pathname=\"\",\n151\t            lineno=0,\n152\t            msg=\"sk-1234567890abcdefghijklmnop\",\n153\t            args=(),\n154\t            exc_info=None,\n155\t        )\n156\t        filt.filter(record)\n157\t        assert \"sk-1234567890\" not in record.msg\n158\t        assert \"***MASKED***\" in record.msg\n159\t\n160\t    def test_filter_always_returns_true(self):\n161\t        filt = _SecretMaskingFilter()\n162\t        record = logging.LogRecord(\n163\t            name=\"test\",\n164\t            level=logging.INFO,\n165\t            pathname=\"\",\n166\t            lineno=0,\n167\t            msg=\"hello\",\n168\t            args=(),\n169\t            exc_info=None,\n170\t        )\n171\t        assert filt.filter(record) is True\n172\t\n173\t    def test_filter_masks_string_args(self):\n174\t        filt = _SecretMaskingFilter()\n175\t        record = logging.LogRecord(\n176\t            name=\"test\",\n177\t            level=logging.INFO,\n178\t            pathname=\"\",\n179\t            lineno=0,\n180\t            msg=\"key=%s\",\n181\t            args=(\"sk-1234567890abcdefghijklmnop\",),\n182\t            exc_info=None,\n183\t        )\n184\t        filt.filter(record)\n185\t        assert \"sk-1234567890\" not in record.args[0]\n186\t\n187\t\n188\t# ---------------------------------------------------------------------------\n189\t# task_log context manager\n190\t# ---------------------------------------------------------------------------\n191\t\n192\t\n193\tclass TestTaskLog:\n194\t    def test_duration_ms_logged(self):\n195\t        \"\"\"task_log emits a record with duration_ms set.\"\"\"\n196\t        captured: list[logging.LogRecord] = []\n197\t\n198\t        class _Capture(logging.Handler):\n199\t            def emit(self, record: logging.LogRecord) -> None:\n200\t                captured.append(record)\n201\t\n202\t        logger = logging.getLogger(\"test.task_log\")\n203\t        logger.addHandler(_Capture())\n204\t        logger.setLevel(logging.DEBUG)\n205\t        logger.propagate = False\n206\t\n207\t        with task_log(logger, \"my_task\"):\n208\t            pass\n209\t\n210\t        assert len(captured) == 1\n211\t        assert hasattr(captured[0], \"duration_ms\")\n212\t        assert isinstance(captured[0].duration_ms, int)\n213\t        assert captured[0].duration_ms >= 0\n214\t\n215\t    def test_task_name_in_log_message(self):\n216\t        captured: list[logging.LogRecord] = []\n217\t\n218\t        class _Capture(logging.Handler):\n219\t            def emit(self, record: logging.LogRecord) -> None:\n220\t                captured.append(record)\n221\t\n222\t        logger = logging.getLogger(\"test.task_log2\")\n223\t        logger.addHandler(_Capture())\n224\t        logger.setLevel(logging.DEBUG)\n225\t        logger.propagate = False\n226\t\n227\t        with task_log(logger, \"enrich_message\"):\n228\t            pass\n229\t\n230\t        assert \"enrich_message\" in captured[0].getMessage()\n231\t\n232\t    def test_exception_propagates(self):\n233\t        logger = logging.getLogger(\"test.task_log3\")\n234\t        logger.propagate = False\n235\t\n236\t        with pytest.raises(ValueError, match=\"boom\"):\n237\t            with task_log(logger, \"failing_task\"):\n238\t                raise ValueError(\"boom\")\n239\t\n240\t    def test_duration_logged_even_on_exception(self):\n241\t        captured: list[logging.LogRecord] = []\n242\t\n243\t        class _Capture(logging.Handler):\n244\t            def emit(self, record: logging.LogRecord) -> None:\n245\t                captured.append(record)\n246\t\n247\t        logger = logging.getLogger(\"test.task_log4\")\n248\t        logger.addHandler(_Capture())\n249\t        logger.setLevel(logging.DEBUG)\n250\t        logger.propagate = False\n251\t\n252\t        with pytest.raises(RuntimeError):\n253\t            with task_log(logger, \"failing\"):\n254\t                raise RuntimeError(\"oops\")\n255\t\n256\t        assert len(captured) == 1\n257\t        assert hasattr(captured[0], \"duration_ms\")\n258\t\n259\t\n260\t# ---------------------------------------------------------------------------\n261\t# configure_logging\n262\t# ---------------------------------------------------------------------------\n263\t\n264\t\n265\tclass TestConfigureLogging:\n266\t    def test_configure_logging_sets_json_handler(self):\n267\t        \"\"\"After configure_logging(), root logger has a handler with JsonFormatter.\"\"\"\n268\t        configure_logging(level=\"DEBUG\")\n269\t        root = logging.getLogger()\n270\t        assert len(root.handlers) >= 1\n271\t        assert any(isinstance(h.formatter, _JsonFormatter) for h in root.handlers)\n272\t\n273\t    def test_configure_logging_is_idempotent(self):\n274\t        \"\"\"Calling configure_logging() twice doesn't stack handlers.\"\"\"\n275\t        configure_logging(level=\"INFO\")\n276\t        count_after_first = len(logging.getLogger().handlers)\n277\t        configure_logging(level=\"INFO\")\n278\t        assert len(logging.getLogger().handlers) == count_after_first\n279\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"57251451-71b9-447a-8e1e-4d99539adbf5","uuid":"9639847d-b04c-4442-80fd-fc357d8c1f59","timestamp":"2026-04-19T02:28:54.921Z","tool_use_result":{"type":"text","file":{"filePath":"/home/wyler-zahm/Desktop/cruse-control/seed-storage-forge/tests/unit/test_logging.py","content":"\"\"\"Unit tests for seed_storage.config logging utilities.\n\nTests JSON formatting, secret masking, required log fields, and task_log\nduration tracking. No real infrastructure or credentials required.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport logging\n\nimport pytest\n\nfrom seed_storage.config import (\n    _JsonFormatter,\n    _mask_secrets,\n    _SecretMaskingFilter,\n    configure_logging,\n    task_log,\n)\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\n\ndef _capture_record(msg: str, level: int = logging.INFO, **kwargs) -> str:\n    \"\"\"Emit a log record through JsonFormatter and return the JSON string.\"\"\"\n    formatter = _JsonFormatter()\n    record = logging.LogRecord(\n        name=\"test.logger\",\n        level=level,\n        pathname=\"\",\n        lineno=0,\n        msg=msg,\n        args=(),\n        exc_info=None,\n    )\n    for k, v in kwargs.items():\n        setattr(record, k, v)\n    return formatter.format(record)\n\n\n# ---------------------------------------------------------------------------\n# JSON format\n# ---------------------------------------------------------------------------\n\n\nclass TestJsonFormat:\n    def test_output_is_valid_json(self):\n        output = _capture_record(\"hello world\")\n        parsed = json.loads(output)  # raises if not valid JSON\n        assert isinstance(parsed, dict)\n\n    def test_required_fields_present(self):\n        parsed = json.loads(_capture_record(\"test message\"))\n        assert \"timestamp\" in parsed\n        assert \"level\" in parsed\n        assert \"name\" in parsed\n        assert \"message\" in parsed\n\n    def test_message_field_contains_log_text(self):\n        parsed = json.loads(_capture_record(\"specific log text\"))\n        assert parsed[\"message\"] == \"specific log text\"\n\n    def test_level_field_matches_log_level(self):\n        parsed = json.loads(_capture_record(\"msg\", level=logging.WARNING))\n        assert parsed[\"level\"] == \"WARNING\"\n\n    def test_name_field_contains_logger_name(self):\n        parsed = json.loads(_capture_record(\"msg\"))\n        assert parsed[\"name\"] == \"test.logger\"\n\n    def test_duration_ms_included_when_present(self):\n        parsed = json.loads(_capture_record(\"msg\", duration_ms=123))\n        assert parsed[\"duration_ms\"] == 123\n\n    def test_duration_ms_absent_when_not_set(self):\n        parsed = json.loads(_capture_record(\"msg\"))\n        assert \"duration_ms\" not in parsed\n\n\n# ---------------------------------------------------------------------------\n# Secret masking\n# ---------------------------------------------------------------------------\n\n\nclass TestSecretMasking:\n    def test_openai_key_masked_in_message(self):\n        output = _capture_record(\"api_key=sk-1234567890abcdef1234567890\")\n        parsed = json.loads(output)\n        assert \"sk-1234567890\" not in parsed[\"message\"]\n        assert \"***MASKED***\" in parsed[\"message\"]\n\n    def test_anthropic_key_masked(self):\n        output = _capture_record(\"key=sk-ant-api03-abcdefghijklmnopqrstuvwxyz123456\")\n        parsed = json.loads(output)\n        assert \"sk-ant-api03\" not in parsed[\"message\"]\n        assert \"***MASKED***\" in parsed[\"message\"]\n\n    def test_groq_key_masked(self):\n        output = _capture_record(\"key=gsk_abcdefghijklmnopqrstuvwxyz12345678\")\n        parsed = json.loads(output)\n        assert \"gsk_abcdefghijklmnopqrstuvwxyz\" not in parsed[\"message\"]\n        assert \"***MASKED***\" in parsed[\"message\"]\n\n    def test_normal_text_not_masked(self):\n        output = _capture_record(\"processing message from #general\")\n        parsed = json.loads(output)\n        assert parsed[\"message\"] == \"processing message from #general\"\n\n    def test_masking_at_debug_level(self):\n        \"\"\"Secrets must be masked even at DEBUG level.\"\"\"\n        output = _capture_record(\"debug: sk-1234567890abcdefghijklmnop\", level=logging.DEBUG)\n        parsed = json.loads(output)\n        assert \"sk-1234567890\" not in parsed[\"message\"]\n        assert \"***MASKED***\" in parsed[\"message\"]\n\n\n# ---------------------------------------------------------------------------\n# _mask_secrets helper\n# ---------------------------------------------------------------------------\n\n\nclass TestMaskSecretsHelper:\n    def test_openai_key_masked(self):\n        result = _mask_secrets(\"key=sk-proj-1234567890abcdefghijklmnop\")\n        assert \"sk-proj-1234567890\" not in result\n        assert \"***MASKED***\" in result\n\n    def test_plain_text_unchanged(self):\n        text = \"no secrets here\"\n        assert _mask_secrets(text) == text\n\n    def test_empty_string_unchanged(self):\n        assert _mask_secrets(\"\") == \"\"\n\n\n# ---------------------------------------------------------------------------\n# SecretMaskingFilter\n# ---------------------------------------------------------------------------\n\n\nclass TestSecretMaskingFilter:\n    def test_filter_masks_record_msg(self):\n        filt = _SecretMaskingFilter()\n        record = logging.LogRecord(\n            name=\"test\",\n            level=logging.INFO,\n            pathname=\"\",\n            lineno=0,\n            msg=\"sk-1234567890abcdefghijklmnop\",\n            args=(),\n            exc_info=None,\n        )\n        filt.filter(record)\n        assert \"sk-1234567890\" not in record.msg\n        assert \"***MASKED***\" in record.msg\n\n    def test_filter_always_returns_true(self):\n        filt = _SecretMaskingFilter()\n        record = logging.LogRecord(\n            name=\"test\",\n            level=logging.INFO,\n            pathname=\"\",\n            lineno=0,\n            msg=\"hello\",\n            args=(),\n            exc_info=None,\n        )\n        assert filt.filter(record) is True\n\n    def test_filter_masks_string_args(self):\n        filt = _SecretMaskingFilter()\n        record = logging.LogRecord(\n            name=\"test\",\n            level=logging.INFO,\n            pathname=\"\",\n            lineno=0,\n            msg=\"key=%s\",\n            args=(\"sk-1234567890abcdefghijklmnop\",),\n            exc_info=None,\n        )\n        filt.filter(record)\n        assert \"sk-1234567890\" not in record.args[0]\n\n\n# ---------------------------------------------------------------------------\n# task_log context manager\n# ---------------------------------------------------------------------------\n\n\nclass TestTaskLog:\n    def test_duration_ms_logged(self):\n        \"\"\"task_log emits a record with duration_ms set.\"\"\"\n        captured: list[logging.LogRecord] = []\n\n        class _Capture(logging.Handler):\n            def emit(self, record: logging.LogRecord) -> None:\n                captured.append(record)\n\n        logger = logging.getLogger(\"test.task_log\")\n        logger.addHandler(_Capture())\n        logger.setLevel(logging.DEBUG)\n        logger.propagate = False\n\n        with task_log(logger, \"my_task\"):\n            pass\n\n        assert len(captured) == 1\n        assert hasattr(captured[0], \"duration_ms\")\n        assert isinstance(captured[0].duration_ms, int)\n        assert captured[0].duration_ms >= 0\n\n    def test_task_name_in_log_message(self):\n        captured: list[logging.LogRecord] = []\n\n        class _Capture(logging.Handler):\n            def emit(self, record: logging.LogRecord) -> None:\n                captured.append(record)\n\n        logger = logging.getLogger(\"test.task_log2\")\n        logger.addHandler(_Capture())\n        logger.setLevel(logging.DEBUG)\n        logger.propagate = False\n\n        with task_log(logger, \"enrich_message\"):\n            pass\n\n        assert \"enrich_message\" in captured[0].getMessage()\n\n    def test_exception_propagates(self):\n        logger = logging.getLogger(\"test.task_log3\")\n        logger.propagate = False\n\n        with pytest.raises(ValueError, match=\"boom\"):\n            with task_log(logger, \"failing_task\"):\n                raise ValueError(\"boom\")\n\n    def test_duration_logged_even_on_exception(self):\n        captured: list[logging.LogRecord] = []\n\n        class _Capture(logging.Handler):\n            def emit(self, record: logging.LogRecord) -> None:\n                captured.append(record)\n\n        logger = logging.getLogger(\"test.task_log4\")\n        logger.addHandler(_Capture())\n        logger.setLevel(logging.DEBUG)\n        logger.propagate = False\n\n        with pytest.raises(RuntimeError):\n            with task_log(logger, \"failing\"):\n                raise RuntimeError(\"oops\")\n\n        assert len(captured) == 1\n        assert hasattr(captured[0], \"duration_ms\")\n\n\n# ---------------------------------------------------------------------------\n# configure_logging\n# ---------------------------------------------------------------------------\n\n\nclass TestConfigureLogging:\n    def test_configure_logging_sets_json_handler(self):\n        \"\"\"After configure_logging(), root logger has a handler with JsonFormatter.\"\"\"\n        configure_logging(level=\"DEBUG\")\n        root = logging.getLogger()\n        assert len(root.handlers) >= 1\n        assert any(isinstance(h.formatter, _JsonFormatter) for h in root.handlers)\n\n    def test_configure_logging_is_idempotent(self):\n        \"\"\"Calling configure_logging() twice doesn't stack handlers.\"\"\"\n        configure_logging(level=\"INFO\")\n        count_after_first = len(logging.getLogger().handlers)\n        configure_logging(level=\"INFO\")\n        assert len(logging.getLogger().handlers) == count_after_first\n","numLines":279,"startLine":1,"totalLines":279}}}
