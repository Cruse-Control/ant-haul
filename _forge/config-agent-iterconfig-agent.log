t is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"57251451-71b9-447a-8e1e-4d99539adbf5","uuid":"f409dc5b-abb5-4e6e-9c83-65d0bb0a79e6","timestamp":"2026-04-19T02:28:58.174Z","tool_use_result":{"type":"text","file":{"filePath":"/home/wyler-zahm/Desktop/cruse-control/seed-storage-forge/pyproject.toml","content":"[project]\nname = \"seed-storage\"\nversion = \"0.2.0\"\ndescription = \"CruseControl knowledge graph — Discord to Neo4j via Graphiti\"\nrequires-python = \">=3.12\"\ndependencies = [\n    # Configuration\n    \"pydantic>=2.0\",\n    \"pydantic-settings>=2.0\",\n    # Graph / LLM\n    \"graphiti-core>=0.3\",\n    \"openai>=1.0\",\n    # HTTP\n    \"httpx>=0.27\",\n    # Queue / task worker\n    \"celery>=5.3\",\n    \"redis>=5.0\",\n    # Discord\n    \"discord.py>=2.3\",\n    # Content resolvers\n    \"trafilatura>=1.12\",\n    \"readability-lxml>=0.8\",\n    \"yt-dlp>=2024.1\",\n    \"beautifulsoup4>=4.12\",\n    \"lxml>=5.0\",\n    \"docling>=2.0\",\n    \"unstructured>=0.14\",\n    \"openai-whisper>=20231117\",\n]\n\n[project.optional-dependencies]\ndev = [\n    \"pytest>=8.0\",\n    \"pytest-asyncio>=0.24\",\n    \"ruff>=0.7\",\n]\n\n[tool.pytest.ini_options]\nasyncio_mode = \"auto\"\ntestpaths = [\"tests\"]\npython_files = [\"test_*.py\"]\npython_classes = [\"Test*\"]\npython_functions = [\"test_*\"]\nmarkers = [\n    \"integration: requires real Redis + Neo4j (docker-compose)\",\n    \"e2e: full-stack end-to-end tests (Celery eager + real infra)\",\n    \"security: security-focused tests (injection, credential isolation)\",\n]\n\n[tool.ruff]\ntarget-version = \"py312\"\nline-length = 100\n\n[tool.ruff.lint]\nselect = [\"E\", \"F\", \"I\", \"UP\"]\nignore = [\"E501\"]\n\n[dependency-groups]\ndev = [\n    \"psycopg2-binary>=2.9.11\",\n]\n","numLines":62,"startLine":1,"totalLines":62}}}
