{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Tsw5cFpQFTULTgiTGtDuQy","type":"tool_result","content":"1\t\"\"\"Unit tests for seed_storage.config.Settings.\n2\t\n3\tAll tests construct fresh Settings() instances with controlled env vars via\n4\tmonkeypatch — no real infrastructure or credentials required.\n5\t\"\"\"\n6\t\n7\tfrom __future__ import annotations\n8\t\n9\timport os\n10\tfrom unittest.mock import patch\n11\t\n12\timport pytest\n13\tfrom pydantic import ValidationError\n14\t\n15\tfrom seed_storage.config import Settings, _read_file\n16\t\n17\t# ---------------------------------------------------------------------------\n18\t# Helpers\n19\t# ---------------------------------------------------------------------------\n20\t\n21\t\n22\tdef make_settings(env: dict[str, str], env_file: str | None = None) -> Settings:\n23\t    \"\"\"Create a Settings instance with only the provided env vars (no .env).\"\"\"\n24\t    with patch.dict(os.environ, env, clear=True):\n25\t        if env_file is None:\n26\t            return Settings(_env_file=None)\n27\t        return Settings(_env_file=env_file)\n28\t\n29\t\n30\t# ---------------------------------------------------------------------------\n31\t# Default values\n32\t# ---------------------------------------------------------------------------\n33\t\n34\t\n35\tclass TestDefaults:\n36\t    def test_neo4j_uri_default(self):\n37\t        s = make_settings({})\n38\t        assert s.NEO4J_URI == \"bolt://neo4j.ant-keeper.svc:7687\"\n39\t\n40\t    def test_redis_url_default(self):\n41\t        s = make_settings({})\n42\t        assert s.REDIS_URL == \"redis://redis.ant-keeper.svc:6379/2\"\n43\t\n44\t    def test_llm_provider_default(self):\n45\t        s = make_settings({})\n46\t        assert s.LLM_PROVIDER == \"openai\"\n47\t\n48\t    def test_daily_budget_default(self):\n49\t        s = make_settings({})\n50\t        assert s.DAILY_LLM_BUDGET == 5.00\n51\t\n52\t    def test_hard_depth_ceiling_default(self):\n53\t        s = make_settings({})\n54\t        assert s.HARD_DEPTH_CEILING == 5\n55\t\n56\t    def test_max_expansion_breadth_default(self):\n57\t        s = make_settings({})\n58\t        assert s.MAX_EXPANSION_BREADTH == 20\n59\t\n60\t    def test_frontier_auto_enabled_default(self):\n61\t        s = make_settings({})\n62\t        assert s.FRONTIER_AUTO_ENABLED is False\n63\t\n64\t    def test_group_id_default(self):\n65\t        s = make_settings({})\n66\t        assert s.GROUP_ID == \"seed-storage\"\n67\t\n68\t    def test_transcription_backend_default(self):\n69\t        s = make_settings({})\n70\t        assert s.TRANSCRIPTION_BACKEND == \"whisper\"\n71\t\n72\t    def test_vision_provider_defaults_to_llm_provider(self):\n73\t        s = make_settings({\"LLM_PROVIDER\": \"openai\"})\n74\t        assert s.VISION_PROVIDER == \"openai\"\n75\t\n76\t\n77\t# ---------------------------------------------------------------------------\n78\t# File-mode credential loading\n79\t# ---------------------------------------------------------------------------\n80\t\n81\t\n82\tclass TestFileCredentials:\n83\t    def test_neo4j_password_from_file(self, tmp_path):\n84\t        secret_file = tmp_path / \"neo4j_password\"\n85\t        secret_file.write_text(\"super-secret-neo4j-pw\\n\")\n86\t\n87\t        s = make_settings({\"NEO4J_PASSWORD_PATH\": str(secret_file)})\n88\t        assert s.NEO4J_PASSWORD == \"super-secret-neo4j-pw\"\n89\t\n90\t    def test_discord_token_from_file(self, tmp_path):\n91\t        token_file = tmp_path / \"discord_token\"\n92\t        token_file.write_text(\"MTIzNDU2Nzg5.token.here\")\n93\t\n94\t        s = make_settings({\"DISCORD_BOT_TOKEN_PATH\": str(token_file)})\n95\t        assert s.DISCORD_BOT_TOKEN == \"MTIzNDU2Nzg5.token.here\"\n96\t\n97\t    def test_webhook_url_from_file(self, tmp_path):\n98\t        hook_file = tmp_path / \"webhook_url\"\n99\t        hook_file.write_text(\"https://discord.com/api/webhooks/123/abc\")\n100\t\n101\t        s = make_settings({\"DISCORD_ALERTS_WEBHOOK_PATH\": str(hook_file)})\n102\t        assert s.DISCORD_ALERTS_WEBHOOK_URL == \"https://discord.com/api/webhooks/123/abc\"\n103\t\n104\t    def test_github_token_from_file(self, tmp_path):\n105\t        tok_file = tmp_path / \"github_token\"\n106\t        tok_file.write_text(\"ghp_example_token_12345\")\n107\t\n108\t        s = make_settings({\"GITHUB_TOKEN_PATH\": str(tok_file)})\n109\t        assert s.GITHUB_TOKEN == \"ghp_example_token_12345\"\n110\t\n111\t    def test_file_cred_strips_trailing_whitespace(self, tmp_path):\n112\t        secret_file = tmp_path / \"neo4j_password\"\n113\t        secret_file.write_text(\"  password-with-spaces  \\n\")\n114\t\n115\t        s = make_settings({\"NEO4J_PASSWORD_PATH\": str(secret_file)})\n116\t        assert s.NEO4J_PASSWORD == \"password-with-spaces\"\n117\t\n118\t    def test_direct_env_takes_precedence_over_file(self, tmp_path):\n119\t        \"\"\"When both direct env var and path are set, direct env wins.\"\"\"\n120\t        secret_file = tmp_path / \"neo4j_password\"\n121\t        secret_file.write_text(\"from-file\")\n122\t\n123\t        s = make_settings(\n124\t            {\n125\t                \"NEO4J_PASSWORD\": \"from-env\",\n126\t                \"NEO4J_PASSWORD_PATH\": str(secret_file),\n127\t            }\n128\t        )\n129\t        assert s.NEO4J_PASSWORD == \"from-env\"\n130\t\n131\t    def test_missing_file_path_leaves_field_empty(self, tmp_path):\n132\t        nonexistent = str(tmp_path / \"does_not_exist\")\n133\t        s = make_settings({\"NEO4J_PASSWORD_PATH\": nonexistent})\n134\t        assert s.NEO4J_PASSWORD == \"\"\n135\t\n136\t\n137\t# ---------------------------------------------------------------------------\n138\t# Missing credentials → ValueError (via validate_credentials)\n139\t# ---------------------------------------------------------------------------\n140\t\n141\t\n142\tclass TestValidateCredentials:\n143\t    def test_missing_llm_api_key_raises(self):\n144\t        s = make_settings({\"LLM_PROVIDER\": \"openai\", \"OPENAI_API_KEY\": \"\"})\n145\t        with pytest.raises(ValueError, match=\"LLM_PROVIDER\"):\n146\t            s.validate_credentials()\n147\t\n148\t    def test_missing_openai_key_for_embeddings_raises(self):\n149\t        \"\"\"Even if using anthropic provider, OPENAI_API_KEY must be set for embeddings.\"\"\"\n150\t        s = make_settings(\n151\t            {\n152\t                \"LLM_PROVIDER\": \"anthropic\",\n153\t                \"ANTHROPIC_API_KEY\": \"sk-ant-test\",\n154\t                \"OPENAI_API_KEY\": \"\",\n155\t            }\n156\t        )\n157\t        with pytest.raises(ValueError, match=\"OPENAI_API_KEY\"):\n158\t            s.validate_credentials()\n159\t\n160\t    def test_missing_discord_token_raises(self):\n161\t        s = make_settings(\n162\t            {\n163\t                \"LLM_PROVIDER\": \"openai\",\n164\t                \"OPENAI_API_KEY\": \"sk-test\",\n165\t                \"DISCORD_BOT_TOKEN\": \"\",\n166\t            }\n167\t        )\n168\t        with pytest.raises(ValueError, match=\"DISCORD_BOT_TOKEN\"):\n169\t            s.validate_credentials()\n170\t\n171\t    def test_all_credentials_present_does_not_raise(self):\n172\t        s = make_settings(\n173\t            {\n174\t                \"LLM_PROVIDER\": \"openai\",\n175\t                \"OPENAI_API_KEY\": \"sk-test-key\",\n176\t                \"DISCORD_BOT_TOKEN\": \"Bot my.token.here\",\n177\t            }\n178\t        )\n179\t        s.validate_credentials()  # must not raise\n180\t\n181\t\n182\t# ---------------------------------------------------------------------------\n183\t# LLM_API_KEY resolution per provider\n184\t# ---------------------------------------------------------------------------\n185\t\n186\t\n187\tclass TestLlmApiKeyResolution:\n188\t    def test_openai_key_returned_for_openai_provider(self):\n189\t        s = make_settings({\"LLM_PROVIDER\": \"openai\", \"OPENAI_API_KEY\": \"sk-openai-abc\"})\n190\t        assert s.llm_api_key == \"sk-openai-abc\"\n191\t\n192\t    def test_anthropic_key_returned_for_anthropic_provider(self):\n193\t        s = make_settings({\"LLM_PROVIDER\": \"anthropic\", \"ANTHROPIC_API_KEY\": \"sk-ant-abc\"})\n194\t        assert s.llm_api_key == \"sk-ant-abc\"\n195\t\n196\t    def test_groq_key_returned_for_groq_provider(self):\n197\t        s = make_settings({\"LLM_PROVIDER\": \"groq\", \"GROQ_API_KEY\": \"gsk_abc123\"})\n198\t        assert s.llm_api_key == \"gsk_abc123\"\n199\t\n200\t    def test_llm_api_key_empty_when_no_key_set(self):\n201\t        s = make_settings({\"LLM_PROVIDER\": \"openai\"})\n202\t        assert s.llm_api_key == \"\"\n203\t\n204\t\n205\t# ---------------------------------------------------------------------------\n206\t# DISCORD_CHANNEL_IDS parsing\n207\t# ---------------------------------------------------------------------------\n208\t\n209\t\n210\tclass TestDiscordChannelIds:\n211\t    def test_comma_separated_ids_parsed(self):\n212\t        s = make_settings({\"DISCORD_CHANNEL_IDS\": \"111,222,333\"})\n213\t        assert s.discord_channel_ids == [\"111\", \"222\", \"333\"]\n214\t\n215\t    def test_empty_string_returns_empty_list(self):\n216\t        s = make_settings({})\n217\t        assert s.discord_channel_ids == []\n218\t\n219\t    def test_whitespace_around_ids_stripped(self):\n220\t        s = make_settings({\"DISCORD_CHANNEL_IDS\": \" 111 , 222 , 333 \"})\n221\t        assert s.discord_channel_ids == [\"111\", \"222\", \"333\"]\n222\t\n223\t    def test_single_id_parsed(self):\n224\t        s = make_settings({\"DISCORD_CHANNEL_IDS\": \"123456789\"})\n225\t        assert s.discord_channel_ids == [\"123456789\"]\n226\t\n227\t    def test_trailing_comma_ignored(self):\n228\t        s = make_settings({\"DISCORD_CHANNEL_IDS\": \"111,222,\"})\n229\t        assert s.discord_channel_ids == [\"111\", \"222\"]\n230\t\n231\t\n232\t# ---------------------------------------------------------------------------\n233\t# TRANSCRIPTION_BACKEND validation\n234\t# ---------------------------------------------------------------------------\n235\t\n236\t\n237\tclass TestTranscriptionBackend:\n238\t    def test_invalid_backend_raises_value_error(self):\n239\t        with pytest.raises(ValidationError, match=\"TRANSCRIPTION_BACKEND\"):\n240\t            make_settings({\"TRANSCRIPTION_BACKEND\": \"invalid_backend\"})\n241\t\n242\t    def test_assemblyai_backend_accepted(self):\n243\t        s = make_settings({\"TRANSCRIPTION_BACKEND\": \"assemblyai\"})\n244\t        assert s.TRANSCRIPTION_BACKEND == \"assemblyai\"\n245\t\n246\t    def test_whisper_backend_accepted(self):\n247\t        s = make_settings({\"TRANSCRIPTION_BACKEND\": \"whisper\"})\n248\t        assert s.TRANSCRIPTION_BACKEND == \"whisper\"\n249\t\n250\t\n251\t# ---------------------------------------------------------------------------\n252\t# VISION_PROVIDER defaults\n253\t# ---------------------------------------------------------------------------\n254\t\n255\t\n256\tclass TestVisionProvider:\n257\t    def test_vision_provider_defaults_to_llm_provider(self):\n258\t        s = make_settings({\"LLM_PROVIDER\": \"openai\"})\n259\t        assert s.VISION_PROVIDER == \"openai\"\n260\t\n261\t    def test_vision_provider_explicit_value_preserved(self):\n262\t        s = make_settings({\"LLM_PROVIDER\": \"openai\", \"VISION_PROVIDER\": \"anthropic\"})\n263\t        assert s.VISION_PROVIDER == \"anthropic\"\n264\t\n265\t    def test_vision_provider_inherits_groq(self):\n266\t        s = make_settings({\"LLM_PROVIDER\": \"groq\"})\n267\t        assert s.VISION_PROVIDER == \"groq\"\n268\t\n269\t\n270\t# ---------------------------------------------------------------------------\n271\t# LLM_PROVIDER validation\n272\t# ---------------------------------------------------------------------------\n273\t\n274\t\n275\tclass TestLlmProviderValidation:\n276\t    def test_invalid_llm_provider_raises(self):\n277\t        with pytest.raises(ValidationError, match=\"LLM_PROVIDER\"):\n278\t            make_settings({\"LLM_PROVIDER\": \"gemini\"})\n279\t\n280\t    def test_valid_providers_accepted(self):\n281\t        for provider in (\"openai\", \"anthropic\", \"groq\"):\n282\t            s = make_settings({\"LLM_PROVIDER\": provider})\n283\t            assert s.LLM_PROVIDER == provider\n284\t\n285\t\n286\t# ---------------------------------------------------------------------------\n287\t# Env var precedence over .env file\n288\t# ---------------------------------------------------------------------------\n289\t\n290\t\n291\tclass TestEnvPrecedence:\n292\t    def test_env_var_beats_dotenv(self, tmp_path):\n293\t        dotenv = tmp_path / \".env\"\n294\t        dotenv.write_text(\"REDIS_URL=redis://from-dotenv/0\\n\")\n295\t\n296\t        with patch.dict(os.environ, {\"REDIS_URL\": \"redis://from-env/2\"}, clear=True):\n297\t            s = Settings(_env_file=str(dotenv))\n298\t\n299\t        assert s.REDIS_URL == \"redis://from-env/2\"\n300\t\n301\t    def test_dotenv_value_used_when_no_env_override(self, tmp_path):\n302\t        dotenv = tmp_path / \".env\"\n303\t        dotenv.write_text(\"NEO4J_USER=dotenv-user\\n\")\n304\t\n305\t        with patch.dict(os.environ, {}, clear=True):\n306\t            s = Settings(_env_file=str(dotenv))\n307\t\n308\t        assert s.NEO4J_USER == \"dotenv-user\"\n309\t\n310\t\n311\t# ---------------------------------------------------------------------------\n312\t# _read_file helper\n313\t# ---------------------------------------------------------------------------\n314\t\n315\t\n316\tclass TestReadFileHelper:\n317\t    def test_reads_existing_file(self, tmp_path):\n318\t        f = tmp_path / \"secret\"\n319\t        f.write_text(\"my-secret\\n\")\n320\t        assert _read_file(str(f)) == \"my-secret\"\n321\t\n322\t    def test_returns_empty_for_missing_file(self, tmp_path):\n323\t        assert _read_file(str(tmp_path / \"nonexistent\")) == \"\"\n324\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"57251451-71b9-447a-8e1e-4d99539adbf5","uuid":"40a4a9d2-e834-49ba-83d9-4769860ef3c8","timestamp":"2026-04-19T02:28:54.368Z","tool_use_result":{"type":"text","file":{"filePath":"/home/wyler-zahm/Desktop/cruse-control/seed-storage-forge/tests/unit/test_config.py","content":"\"\"\"Unit tests for seed_storage.config.Settings.\n\nAll tests construct fresh Settings() instances with controlled env vars via\nmonkeypatch — no real infrastructure or credentials required.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nfrom unittest.mock import patch\n\nimport pytest\nfrom pydantic import ValidationError\n\nfrom seed_storage.config import Settings, _read_file\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\n\ndef make_settings(env: dict[str, str], env_file: str | None = None) -> Settings:\n    \"\"\"Create a Settings instance with only the provided env vars (no .env).\"\"\"\n    with patch.dict(os.environ, env, clear=True):\n        if env_file is None:\n            return Settings(_env_file=None)\n        return Settings(_env_file=env_file)\n\n\n# ---------------------------------------------------------------------------\n# Default values\n# ---------------------------------------------------------------------------\n\n\nclass TestDefaults:\n    def test_neo4j_uri_default(self):\n        s = make_settings({})\n        assert s.NEO4J_URI == \"bolt://neo4j.ant-keeper.svc:7687\"\n\n    def test_redis_url_default(self):\n        s = make_settings({})\n        assert s.REDIS_URL == \"redis://redis.ant-keeper.svc:6379/2\"\n\n    def test_llm_provider_default(self):\n        s = make_settings({})\n        assert s.LLM_PROVIDER == \"openai\"\n\n    def test_daily_budget_default(self):\n        s = make_settings({})\n        assert s.DAILY_LLM_BUDGET == 5.00\n\n    def test_hard_depth_ceiling_default(self):\n        s = make_settings({})\n        assert s.HARD_DEPTH_CEILING == 5\n\n    def test_max_expansion_breadth_default(self):\n        s = make_settings({})\n        assert s.MAX_EXPANSION_BREADTH == 20\n\n    def test_frontier_auto_enabled_default(self):\n        s = make_settings({})\n        assert s.FRONTIER_AUTO_ENABLED is False\n\n    def test_group_id_default(self):\n        s = make_settings({})\n        assert s.GROUP_ID == \"seed-storage\"\n\n    def test_transcription_backend_default(self):\n        s = make_settings({})\n        assert s.TRANSCRIPTION_BACKEND == \"whisper\"\n\n    def test_vision_provider_defaults_to_llm_provider(self):\n        s = make_settings({\"LLM_PROVIDER\": \"openai\"})\n        assert s.VISION_PROVIDER == \"openai\"\n\n\n# ---------------------------------------------------------------------------\n# File-mode credential loading\n# ---------------------------------------------------------------------------\n\n\nclass TestFileCredentials:\n    def test_neo4j_password_from_file(self, tmp_path):\n        secret_file = tmp_path / \"neo4j_password\"\n        secret_file.write_text(\"super-secret-neo4j-pw\\n\")\n\n        s = make_settings({\"NEO4J_PASSWORD_PATH\": str(secret_file)})\n        assert s.NEO4J_PASSWORD == \"super-secret-neo4j-pw\"\n\n    def test_discord_token_from_file(self, tmp_path):\n        token_file = tmp_path / \"discord_token\"\n        token_file.write_text(\"MTIzNDU2Nzg5.token.here\")\n\n        s = make_settings({\"DISCORD_BOT_TOKEN_PATH\": str(token_file)})\n        assert s.DISCORD_BOT_TOKEN == \"MTIzNDU2Nzg5.token.here\"\n\n    def test_webhook_url_from_file(self, tmp_path):\n        hook_file = tmp_path / \"webhook_url\"\n        hook_file.write_text(\"https://discord.com/api/webhooks/123/abc\")\n\n        s = make_settings({\"DISCORD_ALERTS_WEBHOOK_PATH\": str(hook_file)})\n        assert s.DISCORD_ALERTS_WEBHOOK_URL == \"https://discord.com/api/webhooks/123/abc\"\n\n    def test_github_token_from_file(self, tmp_path):\n        tok_file = tmp_path / \"github_token\"\n        tok_file.write_text(\"ghp_example_token_12345\")\n\n        s = make_settings({\"GITHUB_TOKEN_PATH\": str(tok_file)})\n        assert s.GITHUB_TOKEN == \"ghp_example_token_12345\"\n\n    def test_file_cred_strips_trailing_whitespace(self, tmp_path):\n        secret_file = tmp_path / \"neo4j_password\"\n        secret_file.write_text(\"  password-with-spaces  \\n\")\n\n        s = make_settings({\"NEO4J_PASSWORD_PATH\": str(secret_file)})\n        assert s.NEO4J_PASSWORD == \"password-with-spaces\"\n\n    def test_direct_env_takes_precedence_over_file(self, tmp_path):\n        \"\"\"When both direct env var and path are set, direct env wins.\"\"\"\n        secret_file = tmp_path / \"neo4j_password\"\n        secret_file.write_text(\"from-file\")\n\n        s = make_settings(\n            {\n                \"NEO4J_PASSWORD\": \"from-env\",\n                \"NEO4J_PASSWORD_PATH\": str(secret_file),\n            }\n        )\n        assert s.NEO4J_PASSWORD == \"from-env\"\n\n    def test_missing_file_path_leaves_field_empty(self, tmp_path):\n        nonexistent = str(tmp_path / \"does_not_exist\")\n        s = make_settings({\"NEO4J_PASSWORD_PATH\": nonexistent})\n        assert s.NEO4J_PASSWORD == \"\"\n\n\n# ---------------------------------------------------------------------------\n# Missing credentials → ValueError (via validate_credentials)\n# ---------------------------------------------------------------------------\n\n\nclass TestValidateCredentials:\n    def test_missing_llm_api_key_raises(self):\n        s = make_settings({\"LLM_PROVIDER\": \"openai\", \"OPENAI_API_KEY\": \"\"})\n        with pytest.raises(ValueError, match=\"LLM_PROVIDER\"):\n            s.validate_credentials()\n\n    def test_missing_openai_key_for_embeddings_raises(self):\n        \"\"\"Even if using anthropic provider, OPENAI_API_KEY must be set for embeddings.\"\"\"\n        s = make_settings(\n            {\n                \"LLM_PROVIDER\": \"anthropic\",\n                \"ANTHROPIC_API_KEY\": \"sk-ant-test\",\n                \"OPENAI_API_KEY\": \"\",\n            }\n        )\n        with pytest.raises(ValueError, match=\"OPENAI_API_KEY\"):\n            s.validate_credentials()\n\n    def test_missing_discord_token_raises(self):\n        s = make_settings(\n            {\n                \"LLM_PROVIDER\": \"openai\",\n                \"OPENAI_API_KEY\": \"sk-test\",\n                \"DISCORD_BOT_TOKEN\": \"\",\n            }\n        )\n        with pytest.raises(ValueError, match=\"DISCORD_BOT_TOKEN\"):\n            s.validate_credentials()\n\n    def test_all_credentials_present_does_not_raise(self):\n        s = make_settings(\n            {\n                \"LLM_PROVIDER\": \"openai\",\n                \"OPENAI_API_KEY\": \"sk-test-key\",\n                \"DISCORD_BOT_TOKEN\": \"Bot my.token.here\",\n            }\n        )\n        s.validate_credentials()  # must not raise\n\n\n# ---------------------------------------------------------------------------\n# LLM_API_KEY resolution per provider\n# ---------------------------------------------------------------------------\n\n\nclass TestLlmApiKeyResolution:\n    def test_openai_key_returned_for_openai_provider(self):\n        s = make_settings({\"LLM_PROVIDER\": \"openai\", \"OPENAI_API_KEY\": \"sk-openai-abc\"})\n        assert s.llm_api_key == \"sk-openai-abc\"\n\n    def test_anthropic_key_returned_for_anthropic_provider(self):\n        s = make_settings({\"LLM_PROVIDER\": \"anthropic\", \"ANTHROPIC_API_KEY\": \"sk-ant-abc\"})\n        assert s.llm_api_key == \"sk-ant-abc\"\n\n    def test_groq_key_returned_for_groq_provider(self):\n        s = make_settings({\"LLM_PROVIDER\": \"groq\", \"GROQ_API_KEY\": \"gsk_abc123\"})\n        assert s.llm_api_key == \"gsk_abc123\"\n\n    def test_llm_api_key_empty_when_no_key_set(self):\n        s = make_settings({\"LLM_PROVIDER\": \"openai\"})\n        assert s.llm_api_key == \"\"\n\n\n# ---------------------------------------------------------------------------\n# DISCORD_CHANNEL_IDS parsing\n# ---------------------------------------------------------------------------\n\n\nclass TestDiscordChannelIds:\n    def test_comma_separated_ids_parsed(self):\n        s = make_settings({\"DISCORD_CHANNEL_IDS\": \"111,222,333\"})\n        assert s.discord_channel_ids == [\"111\", \"222\", \"333\"]\n\n    def test_empty_string_returns_empty_list(self):\n        s = make_settings({})\n        assert s.discord_channel_ids == []\n\n    def test_whitespace_around_ids_stripped(self):\n        s = make_settings({\"DISCORD_CHANNEL_IDS\": \" 111 , 222 , 333 \"})\n        assert s.discord_channel_ids == [\"111\", \"222\", \"333\"]\n\n    def test_single_id_parsed(self):\n        s = make_settings({\"DISCORD_CHANNEL_IDS\": \"123456789\"})\n        assert s.discord_channel_ids == [\"123456789\"]\n\n    def test_trailing_comma_ignored(self):\n        s = make_settings({\"DISCORD_CHANNEL_IDS\": \"111,222,\"})\n        assert s.discord_channel_ids == [\"111\", \"222\"]\n\n\n# ---------------------------------------------------------------------------\n# TRANSCRIPTION_BACKEND validation\n# ---------------------------------------------------------------------------\n\n\nclass TestTranscriptionBackend:\n    def test_invalid_backend_raises_value_error(self):\n        with pytest.raises(ValidationError, match=\"TRANSCRIPTION_BACKEND\"):\n            make_settings({\"TRANSCRIPTION_BACKEND\": \"invalid_backend\"})\n\n    def test_assemblyai_backend_accepted(self):\n        s = make_settings({\"TRANSCRIPTION_BACKEND\": \"assemblyai\"})\n        assert s.TRANSCRIPTION_BACKEND == \"assemblyai\"\n\n    def test_whisper_backend_accepted(self):\n        s = make_settings({\"TRANSCRIPTION_BACKEND\": \"whisper\"})\n        assert s.TRANSCRIPTION_BACKEND == \"whisper\"\n\n\n# ---------------------------------------------------------------------------\n# VISION_PROVIDER defaults\n# ---------------------------------------------------------------------------\n\n\nclass TestVisionProvider:\n    def test_vision_provider_defaults_to_llm_provider(self):\n        s = make_settings({\"LLM_PROVIDER\": \"openai\"})\n        assert s.VISION_PROVIDER == \"openai\"\n\n    def test_vision_provider_explicit_value_preserved(self):\n        s = make_settings({\"LLM_PROVIDER\": \"openai\", \"VISION_PROVIDER\": \"anthropic\"})\n        assert s.VISION_PROVIDER == \"anthropic\"\n\n    def test_vision_provider_inherits_groq(self):\n        s = make_settings({\"LLM_PROVIDER\": \"groq\"})\n        assert s.VISION_PROVIDER == \"groq\"\n\n\n# ---------------------------------------------------------------------------\n# LLM_PROVIDER validation\n# ---------------------------------------------------------------------------\n\n\nclass TestLlmProviderValidation:\n    def test_invalid_llm_provider_raises(self):\n        with pytest.raises(ValidationError, match=\"LLM_PROVIDER\"):\n            make_settings({\"LLM_PROVIDER\": \"gemini\"})\n\n    def test_valid_providers_accepted(self):\n        for provider in (\"openai\", \"anthropic\", \"groq\"):\n            s = make_settings({\"LLM_PROVIDER\": provider})\n            assert s.LLM_PROVIDER == provider\n\n\n# ---------------------------------------------------------------------------\n# Env var precedence over .env file\n# ---------------------------------------------------------------------------\n\n\nclass TestEnvPrecedence:\n    def test_env_var_beats_dotenv(self, tmp_path):\n        dotenv = tmp_path / \".env\"\n        dotenv.write_text(\"REDIS_URL=redis://from-dotenv/0\\n\")\n\n        with patch.dict(os.environ, {\"REDIS_URL\": \"redis://from-env/2\"}, clear=True):\n            s = Settings(_env_file=str(dotenv))\n\n        assert s.REDIS_URL == \"redis://from-env/2\"\n\n    def test_dotenv_value_used_when_no_env_override(self, tmp_path):\n        dotenv = tmp_path / \".env\"\n        dotenv.write_text(\"NEO4J_USER=dotenv-user\\n\")\n\n        with patch.dict(os.environ, {}, clear=True):\n            s = Settings(_env_file=str(dotenv))\n\n        assert s.NEO4J_USER == \"dotenv-user\"\n\n\n# ---------------------------------------------------------------------------\n# _read_file helper\n# ---------------------------------------------------------------------------\n\n\nclass TestReadFileHelper:\n    def test_reads_existing_file(self, tmp_path):\n        f = tmp_path / \"secret\"\n        f.write_text(\"my-secret\\n\")\n        assert _read_file(str(f)) == \"my-secret\"\n\n    def test_returns_empty_for_missing_file(self, tmp_path):\n        assert _read_file(str(tmp_path / \"nonexistent\")) == \"\"\n","numLines":324,"startLine":1,"totalLines":324}}}
