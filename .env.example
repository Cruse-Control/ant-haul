# seed-storage — environment variable reference
# Copy to .env and fill in values. Never commit .env.
#
# Credentials injected by ant-keeper use file-mode (PATH variants).
# All PATH vars point to files containing the raw secret; the file is read at startup.

# ---------------------------------------------------------------------------
# Neo4j — graph database
# ---------------------------------------------------------------------------

# Bolt connection URI (K8s: NodePort 30687)
NEO4J_URI=bolt://neo4j.ant-keeper.svc:7687

# Neo4j username (default: neo4j)
NEO4J_USER=neo4j

# Neo4j password — set directly OR via file path (ant-keeper file-mode)
NEO4J_PASSWORD=
NEO4J_PASSWORD_PATH=

# ---------------------------------------------------------------------------
# Redis — queue, dedup, rate-limit, circuit breaker, cost tracking
# DB 2 is reserved for seed-storage (DB 0 = ant-keeper, avoid collision)
# ---------------------------------------------------------------------------

REDIS_URL=redis://redis.ant-keeper.svc:6379/2

# ---------------------------------------------------------------------------
# Discord bot — ingestion source
# ---------------------------------------------------------------------------

# Bot token — set directly OR via file path (ant-keeper file-mode)
DISCORD_BOT_TOKEN=
DISCORD_BOT_TOKEN_PATH=

# Comma-separated list of Discord channel IDs to monitor
# Example: DISCORD_CHANNEL_IDS=123456789012345678,987654321098765432
DISCORD_CHANNEL_IDS=

# ---------------------------------------------------------------------------
# Discord alerts webhook — circuit breaker / budget / dead-letter alerts
# ---------------------------------------------------------------------------

# Webhook URL — set directly OR via file path (ant-keeper file-mode)
DISCORD_ALERTS_WEBHOOK_URL=
DISCORD_ALERTS_WEBHOOK_PATH=

# ---------------------------------------------------------------------------
# LLM provider
# ---------------------------------------------------------------------------

# Provider: openai | anthropic | groq  (default: openai)
LLM_PROVIDER=openai

# OpenAI — required for embeddings regardless of LLM_PROVIDER
OPENAI_API_KEY=

# Anthropic (only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Groq (only needed if LLM_PROVIDER=groq)
GROQ_API_KEY=

# LLM model name (default: gpt-4o-mini for openai)
LLM_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Vision provider — for image resolver
# Defaults to LLM_PROVIDER when not set.
# ---------------------------------------------------------------------------

VISION_PROVIDER=

# ---------------------------------------------------------------------------
# Transcription backend — for video/audio resolver
# ---------------------------------------------------------------------------

# Backend: whisper | assemblyai  (default: whisper)
TRANSCRIPTION_BACKEND=whisper

# AssemblyAI (only needed if TRANSCRIPTION_BACKEND=assemblyai)
ASSEMBLYAI_API_KEY=

# ---------------------------------------------------------------------------
# GitHub (optional) — for github resolver
# ---------------------------------------------------------------------------

GITHUB_TOKEN=
GITHUB_TOKEN_PATH=

# ---------------------------------------------------------------------------
# Budget / expansion limits
# ---------------------------------------------------------------------------

# Hard daily LLM spend ceiling in USD. Exceeded → graph_ingest queue pauses.
DAILY_LLM_BUDGET=5.00

# Maximum frontier expansion depth (0 = direct link from message)
HARD_DEPTH_CEILING=5

# Maximum child URLs extracted per resolved content
MAX_EXPANSION_BREADTH=20

# Enable automatic frontier scanning via Celery beat (default: false)
FRONTIER_AUTO_ENABLED=false

# Max add_episode() calls per minute across all workers
RATE_LIMIT_PER_MINUTE=100

# ---------------------------------------------------------------------------
# Celery worker concurrency
# ---------------------------------------------------------------------------

WORKER_CONCURRENCY_RAW=2
WORKER_CONCURRENCY_GRAPH=4

# ---------------------------------------------------------------------------
# API / Health
# ---------------------------------------------------------------------------

# FastAPI app (legacy, kept for backwards compat)
API_HOST=0.0.0.0
API_PORT=7860

# Health endpoint (supervisord process)
HEALTH_PORT=8080

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO
